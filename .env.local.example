# Copy to .env.local and fill in the real values.
# Never commit .env.local.

# ─── Apps Script hub API ─────────────────────────────────────────────
# Exec URL of the Apps Script API deployment (the SECOND deployment,
# executeAs=Me, access=Anyone). Example:
# https://script.google.com/macros/s/AKfycb.../exec
APPS_SCRIPT_API_URL=

# Shared secret. Must match what you set in ScriptProperties as HUB_API_TOKEN.
# Generate with: openssl rand -hex 32
APPS_SCRIPT_API_TOKEN=

# ─── NextAuth (Google OAuth) ─────────────────────────────────────────
# 32+ char random string used to sign session cookies.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Google OAuth 2.0 Client ID + Secret from Google Cloud Console.
# See hub-next/SETUP_OAUTH.md for step-by-step instructions.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Dashboard link ──────────────────────────────────────────────────
# Exec URL of the main Client Dashboard (the FIRST Apps Script
# deployment, executeAs=User accessing). Exposed in the hub's top nav
# so users can jump between apps. Use the /exec URL or your custom
# domain (e.g. https://dashboard.fandf.co.il).
DASHBOARD_URL=

# ─── Dev fallback ────────────────────────────────────────────────────
# Optional. If set AND the user has no NextAuth session, the hub acts
# as this user. Leave blank in any real deployment.
DEV_USER_EMAIL=

# ─── Direct Google Workspace access (bypasses Apps Script) ──────────
# Full SA JSON on ONE line (no newlines). Same JSON that lives in
# Script Property SERVICE_ACCOUNT_KEY_JSON on the Apps Script project.
# Used to impersonate users for Sheets / Calendar / Tasks / Gmail via
# domain-wide delegation. Only needed if USE_SA_TASKS_READS=1.
TASKS_SA_KEY_JSON=

# Canonical spreadsheet IDs — kept as env (not secret) so they're
# swappable per-environment.
SHEET_ID_MAIN=15GKqEy8OelYtGuuiHYkSAR2xNNL4icwo-Wgiq1suW0Y
SHEET_ID_COMMENTS=1ZpdfJhdYa6aD5iftTsGJuVMLTS9WlzHGZMevq5hrxGU

# Feature flag. "1" = reads go direct through googleapis. "" = reads
# go through Apps Script (legacy). Toggle per-env during rollout.
USE_SA_TASKS_READS=1

# Separate flag for the write path (tasksCreate / tasksUpdate). Needs
# the additional DWD scopes /auth/drive, /auth/calendar,
# /auth/gmail.send. Keep empty until scopes + APIs are authorized.
USE_SA_TASKS_WRITES=

# Account impersonated for Drive folder creation. Folders land in this
# user's Drive. Defaults to maayan@fandf.co.il to match the Apps Script
# deployer identity.
DRIVE_FOLDER_OWNER=maayan@fandf.co.il
