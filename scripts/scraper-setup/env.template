# Copy this to .env.local at the repo root, fill in real values from
# the existing fandf-hub/.env.local on the source machine. The scraper
# only needs these four keys; everything else from .env.local is for
# the Next.js app and irrelevant on a scraper-only host.

# Main media-performance spreadsheet. Used to read the Keys tab
# (project list, landing URLs, Yad2 URLs).
SHEET_ID_MAIN=

# Dashboard-comments spreadsheet. Used to write the LANDING_PRICES tab
# the morning-feed alert reads.
SHEET_ID_COMMENTS=

# Service-account JSON, on ONE LINE (no real newlines inside the JSON —
# the `\n` characters in the private key stay as literal `\n`). The
# scraper uses this SA to read the master sheet and write the prices
# tab via DWD impersonation.
TASKS_SA_KEY_JSON=

# The Google-Workspace identity the SA impersonates via Domain-Wide
# Delegation. The SA must be authorised to impersonate this user in the
# Google Admin console; this user must have edit access to both sheets.
DRIVE_FOLDER_OWNER=
