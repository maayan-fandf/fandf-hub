# Copy this to .env.local at the repo root, fill in real values from
# the existing fandf-hub/.env.local on the source machine. The scraper
# only needs these three keys; everything else from .env.local is for
# the Next.js app and irrelevant on a scraper-only host.

# Dashboard-comments spreadsheet. The scraper both READS the project
# list from its `Keysimp` tab (a synced mirror of the master Keys tab)
# AND WRITES the detected prices to its `LANDING_PRICES` tab. Single
# sheet ID = single permission scope on the scraper host.
SHEET_ID_COMMENTS=

# Service-account JSON, on ONE LINE (no real newlines inside the JSON —
# the `\n` characters in the private key stay as literal `\n`). The
# scraper uses this SA to read + write the dashboard-comments sheet
# via DWD impersonation.
TASKS_SA_KEY_JSON=

# The Google-Workspace identity the SA impersonates via Domain-Wide
# Delegation. The SA must be authorised to impersonate this user in the
# Google Admin console; this user must have edit access to the sheet.
DRIVE_FOLDER_OWNER=
