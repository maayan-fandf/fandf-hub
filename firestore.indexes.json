{
  "//": "Composite indexes for the Sheets->Firestore migration (handoff section 4). Single-field lookups -- (umbrella_id), (parent_id), comments.(parentId), pricingLog.(taskId), and array-contains on a lone field like blocked_by -- are auto-indexed by Firestore and intentionally NOT listed here (firestore.indexes.json only carries composite/multi-field + array-with-field indexes). Deploy with: firebase deploy --only firestore:indexes --project fandf-dashboard",
  "indexes": [
    {
      "collectionGroup": "tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "project", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "company", "order": "ASCENDING" },
        { "fieldPath": "project", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "assignees", "arrayConfig": "CONTAINS" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "requested_date", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "comments",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "taskId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "comments",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "mentions", "arrayConfig": "CONTAINS" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "pricingLog",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "month", "order": "ASCENDING" },
        { "fieldPath": "company", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
